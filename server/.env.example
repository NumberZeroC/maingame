# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_game_platform

# Database - MongoDB
MONGO_URI=mongodb://localhost:27017/ai_game_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=ai-game-platform-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# =============================================================================
# AI Service Configuration (OpenAI Protocol Compatible Providers)
# =============================================================================

# Default AI Provider (aliyun_codingplan, zhipu, deepseek, openai)
AI_PROVIDER=openai

# Fallback Configuration
AI_FALLBACK_ENABLED=true
# AI_FALLBACK_ORDER=openai,deepseek,zhipu

# Rate Limiting
AI_RATE_LIMIT_RPM=60
AI_RATE_LIMIT_TPM=90000

# Cost Tracking
AI_COST_TRACKING=true

# =============================================================================
# Aliyun CodingPlan (阿里百炼 CodingPlan) Configuration
# =============================================================================
ALIYUN_CODINGPLAN_API_KEY=your_codingplan_api_key
ALIYUN_CODINGPLAN_MODEL=glm-5
ALIYUN_CODINGPLAN_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ALIYUN_CODINGPLAN_PRIORITY=0

# =============================================================================
# Zhipu (智谱 GLM) Configuration
# =============================================================================
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_MODEL=glm-4-flash
ZHIPU_PRIORITY=1

# =============================================================================
# DeepSeek Configuration
# =============================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_PRIORITY=2

# =============================================================================
# OpenAI Configuration
# =============================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PRIORITY=3

# Storage - OSS (Optional)
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=